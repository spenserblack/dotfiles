root = true

[*]
indent_style = space
end_of_line = LF
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Golang
[*.go]
indent_style = tab

# Web Languages
[*.{js,ts,jsx,tsx}]
indent_style = space
indent_size = 2

[*.{css,scss,styl}]
indent_style = space
indent_size = 2

[*.{html,pug}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
