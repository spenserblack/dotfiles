root = true

[*]
end_of_line = LF
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.go]
indent_style = tab

[*.rs]
indent_style = space
indent_size = 4

# Web Languages {{{
[*.{js,ts,jsx,tsx}]
indent_style = space
indent_size = 2

[*.{css,scss,styl}]
indent_style = space
indent_size = 2

[*.{html,pug}]
indent_style = space
indent_size = 2
# }}}

# Data Files {{{
[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2
# }}}

[Makefile]
indent_style = tab
